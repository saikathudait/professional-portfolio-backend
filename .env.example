PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio
MONGODB_URI_DIRECT=

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-production
ADMIN_NAME=Portfolio Admin

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Use local for development. Use mongodb on Vercel/serverless deployments.
# Use cloudinary only when Cloudinary raw upload credentials are configured.
RESUME_STORAGE=local

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@example.com

FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173

# Groq AI chatbot
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
API_KEY_ENCRYPTION_SECRET=replace-with-a-long-random-secret
PORTFOLIO_OWNER_NAME=Saikat Hudait
PORTFOLIO_OWNER_EMAIL=saikathudait2001@gmail.com
PORTFOLIO_OWNER_LOCATION=Kolkata, India
